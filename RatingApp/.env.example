# Admin Password Hash (BCRYPT HASHED - DO NOT COMMIT .env.local TO GIT)
# 
# To generate a hash for your admin password:
# 1. Run: npm run hash-password
# 2. Enter your desired password when prompted
# 3. Copy the hash to VITE_ADMIN_PASS_HASH below
# 
# Example hash for password "adminbaby":
# VITE_ADMIN_PASS_HASH=$2b$10$5cJdVYVRq5IYdHxMlbBTHeNKQm3kKKBz5gZx2Xq9JKKzY9QfDwJW2

VITE_ADMIN_PASS_HASH=your-bcrypt-hash-here
